{
  "version": 1,
  "project_type": "code",
  "queue": {
    "file": ".ralph/queue.json",
    "done_file": ".ralph/done.json",
    "id_prefix": "RQ",
    "id_width": 4
  },
  "agent": {
    "runner": "codex",
    "model": "gpt-5.2-codex",
    "phases": 3,
    "iterations": 1,
    "reasoning_effort": "medium",
    "followup_reasoning_effort": null,
    "codex_bin": "codex",
    "opencode_bin": "opencode",
    "gemini_bin": "gemini",
    "claude_bin": "claude",
    "claude_permission_mode": "bypass_permissions",
    "repoprompt_plan_required": true,
    "repoprompt_tool_injection": true,
    "ci_gate_command": "make ci",
    "ci_gate_enabled": true,
    "git_commit_push_enabled": true,
    "git_revert_mode": "ask",
    "update_task_before_run": true
  }
}