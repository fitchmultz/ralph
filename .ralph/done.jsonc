      "id": "RQ-0004",
      "status": "done",
      "title": "Consolidate task materialization and slim task command helpers",
      "description": "The audit found that Ralph currently materializes new queue tasks through multiple overlapping paths. `commands/task/mod.rs` is carrying helper-surface, option, runner-resolution, request-reading, and field-diff responsibilities, while follow-up proposal application and task decomposition each allocate IDs, map dependencies, choose insertion points, stamp timestamps, and validate queue writes independently. This work should establish one canonical task-materialization path, reduce boundary drift in the task command surface, and keep follow-up/decomposition behavior aligned for IDs, dependency remapping, timestamps, insertion order, and validation.",
      "priority": "high",
      "tags": [
        "audit",
        "architecture",
        "queue",
        "task-builder",
        "refactor"
      ],
      "scope": [
        "crates/ralph/src/commands/task/mod.rs",
        "crates/ralph/src/commands/task/decompose/",
        "crates/ralph/src/queue/operations/followups.rs",
        "crates/ralph/src/queue/operations/",
        "cargo test -p ralph-agent-loop task",
        "cargo test -p ralph-agent-loop queue"
      ],
      "evidence": [
