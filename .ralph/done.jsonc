        "apps/RalphMac/RalphCore/ConfigModels.swift",
        "apps/RalphMac/RalphCore/MachineContract.swift",
        "apps/RalphMac/RalphCoreTests/"
      ],
      "evidence": [
        "path: apps/RalphMac/RalphCore/WorkspaceManager+Versioning.swift:89 :: executeVersionCheck :: decodes MachineSystemInfoDocument with JSONDecoder directly and performs no version gate",
        "path: apps/RalphMac/RalphCore/ConfigModels.swift:174-181 :: MachineSystemInfoDocument :: has version field but no expectedVersion/documentName contract conformance",
        "path: apps/RalphMac/RalphCore/MachineContract.swift:27-47 :: RalphMachineContract constants :: no system-info version constant is defined",
        "workflow: rg -n \"MachineSystemInfoDocument|expectedVersion\" apps/RalphMac/RalphCore --glob '*.swift' :: found direct decode call and no system-info expectedVersion usage"
      ],
      "plan": [
        "Add `systemInfoVersion` to `RalphMachineContract` and wire it to Rust machine contract expectations.",
        "Make `MachineSystemInfoDocument` adopt `VersionedMachineDocument` with `expectedVersion`/`documentName`.",
        "Update `executeVersionCheck` to decode through `RalphMachineContract.decode(...)` and surface structured version mismatch errors.",
        "Add RalphCore tests for matching vs mismatched system-info versions during version-check flow.",
        "Verify by running `xcodebuild test -project apps/RalphMac/RalphMac.xcodeproj -scheme RalphCore -destination 'platform=macOS,arch=$(uname -m)'` and confirming new version-mismatch tests pass."
