    {
      "id": "RQ-0931",
      "status": "todo",
      "title": "Fix deny_unknown_fields blocking migration of deprecated config keys",
      "description": "ConfigLayer uses deny_unknown_fields which means if a user has a config with a deprecated field, the config will fail to parse BEFORE migrations can run. The migration system cannot help because parsing fails first.",
      "priority": "high",
      "tags": [
        "scan",
        "config",
        "migration",
        "breaking-change"
      ],
      "scope": [
        "crates/ralph/src/config/layer.rs",
        "crates/ralph/src/migration/"
      ],
      "evidence": [
        "path: crates/ralph/src/config/layer.rs :: line 30 :: deny_unknown_fields",
        "analysis: Users must manually remove deprecated fields before upgrading"
      ],
      "plan": [
        "Evaluate impact: list deprecated config keys",
        "Option 1: Remove deny_unknown_fields",
        "Option 2: Run migrations before full config parsing",
        "Add test for deprecated key migration",
        "Run `cargo test -p ralph` to verify"
      ],
      "notes": [],
      "request": "scan finding",
      "created_at": "2026-02-17T19:44:50Z",
      "updated_at": "2026-02-17T19:44:50Z",
      "depends_on": [],
      "blocks": [],
      "relates_to": [],
