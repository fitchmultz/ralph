    {
      "id": "RQ-0050",
      "status": "todo",
      "title": "Bump Ralph's pinned Rust baseline from 1.94.1 to 1.95.0",
      "description": "Update the repository's explicit Rust override to match the system global stable toolchain (`rustc 1.95.0`, `cargo 1.95.0`) and record the baseline in the active source-of-truth docs. The earlier queue shaping accidentally trusted the repo-local `rust-toolchain.toml` override, so this task must reconcile `rust-toolchain.toml`, crate `rust-version`, lockfile behavior, release/versioning scripts, and CI docs around the intended Rust 1.95.0 development baseline.",
      "priority": "high",
      "tags": [
        "rust",
        "toolchain",
        "docs",
        "maintenance"
      ],
      "scope": [
        "rust-toolchain.toml",
        "crates/ralph/Cargo.toml",
        "Cargo.lock",
        "docs/index.md",
        "docs/guides/stack-audit-2026-03.md",
        "docs/decisions.md",
        "docs/guides/ci-strategy.md",
        "docs/releasing.md",
        "scripts/versioning.sh",
        "Makefile",
        "make version-check",
        "make agent-ci"
