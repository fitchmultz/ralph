    {
      "id": "RQ-0019",
      "status": "todo",
      "title": "Include machine schema in release metadata",
      "description": "Principles violated: C) DRY knowledge, H) Operational hygiene, J) Consistency/Integrity. Makefile generate writes three committed schemas, but release metadata policy tracks only config and queue schemas. The release verify manifest and publish staging use RELEASE_METADATA_PATHS, so machine schema changes can be regenerated locally but omitted from the verified release commit. Minimal fix: add schemas/machine.schema.json to RELEASE_METADATA_PATHS and test that every schema generated by the Makefile is included in release metadata.",
      "priority": "high",
      "tags": [
        "maintenance",
        "release",
        "schema"
      ],
      "scope": [
        "Makefile",
        "scripts/lib/release_policy.sh",
        "scripts/lib/release_verify_state.sh",
        "scripts/lib/release_publish_pipeline.sh",
        "crates/ralph/tests/release_script_contract_test.rs"
      ],
      "evidence": [
        "path: Makefile:237 :: generate writes schemas/config.schema.json.",
        "path: Makefile:238 :: generate writes schemas/queue.schema.json.",
        "path: Makefile:239 :: generate writes schemas/machine.schema.json.",
        "path: scripts/lib/release_policy.sh:21 :: RELEASE_METADATA_PATHS defines the canonical release metadata set.",
        "path: scripts/lib/release_policy.sh:28 :: RELEASE_METADATA_PATHS includes schemas/config.schema.json.",
        "path: scripts/lib/release_policy.sh:29 :: RELEASE_METADATA_PATHS includes schemas/queue.schema.json but omits schemas/machine.schema.json.",
        "path: scripts/lib/release_verify_state.sh:88 :: release verification hashes only RELEASE_METADATA_PATHS.",
        "path: scripts/lib/release_publish_pipeline.sh:107 :: release publish stages only RELEASE_METADATA_PATHS.",
        "workflow: rg -n \"RELEASE_METADATA_PATHS|schemas/(config|queue|machine)\\.schema\\.json|git add\" scripts Makefile docs crates/ralph/tests :: showed machine schema generation and release metadata omission."
      ],
      "plan": [
        "Add schemas/machine.schema.json to RELEASE_METADATA_PATHS.",
        "Add a contract test that parses Makefile generate schema outputs and asserts each generated schema appears in release metadata.",
        "Confirm release verify manifests and release publish staging include the machine schema path.",
        "Verify by running the release script contract test and make version-check."
      ],
      "notes": [],
      "request": "scan: Simplify code while preserving nuanced runner behavior",
