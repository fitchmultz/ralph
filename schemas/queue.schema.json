{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "QueueFile",
  "type": "object",
  "properties": {
    "tasks": {
      "type": "array",
      "default": [],
      "items": {
        "$ref": "#/$defs/Task"
      }
    },
    "version": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0
    }
  },
  "additionalProperties": false,
  "required": [
    "version"
  ],
  "$defs": {
    "Model": {
      "oneOf": [
        {
          "description": "OpenAI GPT-5.4 (default Codex model)",
          "type": "string",
          "const": "gpt-5.4"
        },
        {
          "description": "OpenAI GPT-5.3 Codex",
          "type": "string",
          "const": "gpt-5.3-codex"
        },
        {
          "description": "OpenAI GPT-5.3 Codex Spark (fast)",
          "type": "string",
          "const": "gpt-5.3-codex-spark"
        },
        {
          "description": "OpenAI GPT-5.3",
          "type": "string",
          "const": "gpt-5.3"
        },
        {
          "description": "ZhipuAI GLM-4.7",
          "type": "string",
          "const": "zai-coding-plan/glm-4.7"
        },
        {
          "description": "Custom model identifier",
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "PhaseOverrideConfig": {
      "description": "Per-phase configuration overrides for runner, model, and reasoning effort.\n\nAll fields are optional to support leaf-wise merging:\n- `Some(value)` overrides the parent config\n- `None` means \"inherit from parent\"",
      "type": "object",
      "properties": {
        "model": {
          "description": "Model to use for this phase (overrides global agent.model)",
          "anyOf": [
            {
              "$ref": "#/$defs/Model"
            },
            {
              "type": "null"
            }
          ]
        },
        "reasoning_effort": {
          "description": "Reasoning effort for this phase (overrides global agent.reasoning_effort)",
          "anyOf": [
            {
              "$ref": "#/$defs/ReasoningEffort"
            },
            {
              "type": "null"
            }
          ]
        },
        "runner": {
          "description": "Runner to use for this phase (overrides global agent.runner)",
          "anyOf": [
            {
              "$ref": "#/$defs/Runner"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "PhaseOverrides": {
      "description": "Phase overrides container for Phase 1/2/3 execution.\n\nPer-phase configuration for Phase 1/2/3 execution.\n\nInvariants/assumptions:\n- Overrides are defined per phase only; there is no shared `defaults` layer inside\n  `agent.phase_overrides`. Use global `agent.runner` / `agent.model` /\n  `agent.reasoning_effort` for shared defaults.\n- Merging is leaf-wise: `Some(value)` overrides, `None` inherits.",
      "type": "object",
      "properties": {
        "phase1": {
          "description": "Phase 1 specific overrides",
          "anyOf": [
            {
              "$ref": "#/$defs/PhaseOverrideConfig"
            },
            {
              "type": "null"
            }
          ]
        },
        "phase2": {
          "description": "Phase 2 specific overrides",
          "anyOf": [
            {
              "$ref": "#/$defs/PhaseOverrideConfig"
            },
            {
              "type": "null"
            }
          ]
        },
        "phase3": {
          "description": "Phase 3 specific overrides",
          "anyOf": [
            {
              "$ref": "#/$defs/PhaseOverrideConfig"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "ReasoningEffort": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "xhigh"
      ]
    },
    "Runner": {
      "description": "Runner id. Built-in runner IDs: codex, opencode, gemini, claude, cursor, kimi, pi. Plugin runner IDs are also supported as non-empty strings.",
      "type": "string",
      "examples": [
        "claude",
        "acme.super_runner"
      ]
    },
    "RunnerApprovalMode": {
      "oneOf": [
        {
          "description": "Do not apply any approval flags; runner defaults apply.",
          "type": "string",
          "const": "default"
        },
        {
          "description": "Attempt to auto-approve edits but not all tool actions (runner-specific).",
          "type": "string",
          "const": "auto_edits"
        },
        {
          "description": "Bypass approvals / run headless (runner-specific).",
          "type": "string",
          "const": "yolo"
        },
        {
          "description": "Strict safety mode. Warning: some runners may become interactive and hang.",
          "type": "string",
          "const": "safe"
        }
      ]
    },
    "RunnerCliOptionsPatch": {
      "type": "object",
      "properties": {
        "approval_mode": {
          "description": "Desired approval/permission behavior.",
          "anyOf": [
            {
              "$ref": "#/$defs/RunnerApprovalMode"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "output_format": {
          "description": "Desired output format for runner execution.",
          "anyOf": [
            {
              "$ref": "#/$defs/RunnerOutputFormat"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "plan_mode": {
          "description": "Desired plan/read-only behavior (when supported by the runner).",
          "anyOf": [
            {
              "$ref": "#/$defs/RunnerPlanMode"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "sandbox": {
          "description": "Desired sandbox behavior (when supported by the runner).",
          "anyOf": [
            {
              "$ref": "#/$defs/RunnerSandboxMode"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "unsupported_option_policy": {
          "description": "Policy for unsupported options (warn/error/ignore).",
          "anyOf": [
            {
              "$ref": "#/$defs/UnsupportedOptionPolicy"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "verbosity": {
          "description": "Desired verbosity (when supported by the runner).",
          "anyOf": [
            {
              "$ref": "#/$defs/RunnerVerbosity"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "additionalProperties": false
    },
    "RunnerOutputFormat": {
      "oneOf": [
        {
          "description": "Newline-delimited JSON objects (required for Ralph's streaming parser).",
          "type": "string",
          "const": "stream_json"
        },
        {
          "description": "JSON output (may not be streaming; currently treated as unsupported by Ralph execution).",
          "type": "string",
          "const": "json"
        },
        {
          "description": "Plain text output (currently treated as unsupported by Ralph execution).",
          "type": "string",
          "const": "text"
        }
      ]
    },
    "RunnerPlanMode": {
      "type": "string",
      "enum": [
        "default",
        "enabled",
        "disabled"
      ]
    },
    "RunnerSandboxMode": {
      "type": "string",
      "enum": [
        "default",
        "enabled",
        "disabled"
      ]
    },
    "RunnerVerbosity": {
      "type": "string",
      "enum": [
        "quiet",
        "normal",
        "verbose"
      ]
    },
    "Task": {
      "type": "object",
      "properties": {
        "actual_minutes": {
          "description": "Actual time spent on this task in minutes.\nOptional; set manually or computed from started_at to completed_at.",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0
        },
        "agent": {
          "description": "Optional per-task agent override (runner/model/model_effort/phases/iterations/phase_overrides).",
          "anyOf": [
            {
              "$ref": "#/$defs/TaskAgent"
            },
            {
              "type": "null"
            }
          ]
        },
        "blocks": {
          "description": "Task IDs that this task blocks (must be Done/Rejected before blocked tasks can run).\nSemantically different from depends_on: blocks is \"I prevent X\" vs depends_on \"I need X\".",
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "completed_at": {
          "type": [
            "string",
            "null"
          ]
        },
        "created_at": {
          "description": "RFC3339 UTC timestamps as strings to keep the contract tool-agnostic.",
          "type": "string"
        },
        "custom_fields": {
          "description": "Custom user-defined fields (key-value pairs for extensibility).\nValues may be written as string/number/boolean; Ralph coerces them to strings when loading.",
          "type": "object",
          "additionalProperties": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              },
              {
                "type": "boolean"
              }
            ]
          },
          "default": {}
        },
        "depends_on": {
          "description": "Task IDs that this task depends on (must be Done or Rejected before this task can run).",
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "description": {
          "description": "Detailed description of the task's context, goal, purpose, and desired outcome.",
          "type": [
            "string",
            "null"
          ]
        },
        "duplicates": {
          "description": "Task ID that this task duplicates (if any).\nSingular reference, not a list.",
          "type": [
            "string",
            "null"
          ]
        },
        "estimated_minutes": {
          "description": "Estimated time to complete this task in minutes.\nOptional; used for planning and estimation accuracy tracking.",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0
        },
        "evidence": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "id": {
          "type": "string"
        },
        "notes": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "parent_id": {
          "description": "Parent task ID if this is a subtask (child-to-parent reference).",
          "type": [
            "string",
            "null"
          ]
        },
        "plan": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "priority": {
          "$ref": "#/$defs/TaskPriority",
          "default": "medium"
        },
        "relates_to": {
          "description": "Task IDs that this task relates to (loose coupling, no execution constraint).\nBidirectional awareness but no execution constraint.",
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "request": {
          "description": "Original human request that created the task (Task Builder / Scan).",
          "type": [
            "string",
            "null"
          ]
        },
        "scheduled_start": {
          "description": "RFC3339 timestamp when the task should become runnable (optional scheduling).",
          "type": [
            "string",
            "null"
          ]
        },
        "scope": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "started_at": {
          "description": "RFC3339 UTC timestamp when work on this task actually started.\n\nInvariants:\n- Must be RFC3339 UTC (Z) if set.\n- Should be set when transitioning into `doing` (see status policy).",
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "$ref": "#/$defs/TaskStatus",
          "default": "todo"
        },
        "tags": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "title": {
          "type": "string"
        },
        "updated_at": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "created_at",
        "updated_at"
      ]
    },
    "TaskAgent": {
      "type": "object",
      "properties": {
        "followup_reasoning_effort": {
          "description": "Reasoning effort override for follow-up iterations (iterations > 1).",
          "anyOf": [
            {
              "$ref": "#/$defs/ReasoningEffort"
            },
            {
              "type": "null"
            }
          ]
        },
        "iterations": {
          "description": "Number of iterations to run for this task (overrides config).",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint8",
          "maximum": 255,
          "minimum": 1
        },
        "model": {
          "anyOf": [
            {
              "$ref": "#/$defs/Model"
            },
            {
              "type": "null"
            }
          ]
        },
        "model_effort": {
          "description": "Per-task reasoning effort override for runners with reasoning controls. Default falls back to config.",
          "type": "string",
          "default": "default",
          "enum": [
            "default",
            "low",
            "medium",
            "high",
            "xhigh"
          ]
        },
        "phase_overrides": {
          "description": "Optional per-phase runner/model/effort overrides for this task.",
          "anyOf": [
            {
              "$ref": "#/$defs/PhaseOverrides"
            },
            {
              "type": "null"
            }
          ]
        },
        "phases": {
          "description": "Number of execution phases for this task (1, 2, or 3), overriding config defaults.",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint8",
          "maximum": 3,
          "minimum": 1
        },
        "runner": {
          "anyOf": [
            {
              "$ref": "#/$defs/Runner"
            },
            {
              "type": "null"
            }
          ]
        },
        "runner_cli": {
          "description": "Optional normalized runner CLI overrides for this task.\n\nThis is intended to express runner behavior intent (output/approval/sandbox/etc)\nwithout embedding runner-specific flag syntax into the queue.",
          "anyOf": [
            {
              "$ref": "#/$defs/RunnerCliOptionsPatch"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "TaskPriority": {
      "description": "Task priority used for queue ordering and display.",
      "type": "string",
      "enum": [
        "critical",
        "high",
        "medium",
        "low"
      ]
    },
    "TaskStatus": {
      "type": "string",
      "enum": [
        "draft",
        "todo",
        "doing",
        "done",
        "rejected"
      ]
    },
    "UnsupportedOptionPolicy": {
      "type": "string",
      "enum": [
        "ignore",
        "warn",
        "error"
      ]
    }
  }
}
