{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "QueueFile",
  "type": "object",
  "required": [
    "version"
  ],
  "properties": {
    "tasks": {
      "default": [],
      "type": "array",
      "items": {
        "$ref": "#/definitions/Task"
      }
    },
    "version": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0.0
    }
  },
  "additionalProperties": false,
  "definitions": {
    "Model": {
      "type": "string"
    },
    "ReasoningEffort": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "xhigh"
      ]
    },
    "Runner": {
      "type": "string",
      "enum": [
        "codex",
        "opencode",
        "gemini",
        "claude"
      ]
    },
    "Task": {
      "type": "object",
      "required": [
        "id",
        "title"
      ],
      "properties": {
        "agent": {
          "description": "Optional per-task agent override (runner/model/model_effort/iterations).",
          "anyOf": [
            {
              "$ref": "#/definitions/TaskAgent"
            },
            {
              "type": "null"
            }
          ]
        },
        "completed_at": {
          "type": [
            "string",
            "null"
          ]
        },
        "created_at": {
          "description": "RFC3339 UTC timestamps as strings to keep the contract tool-agnostic.",
          "type": [
            "string",
            "null"
          ]
        },
        "custom_fields": {
          "description": "Custom user-defined fields (key-value pairs for extensibility).",
          "default": {},
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "depends_on": {
          "description": "Task IDs that this task depends on (must be Done before this task can run).",
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "id": {
          "type": "string"
        },
        "notes": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "plan": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "priority": {
          "default": "medium",
          "allOf": [
            {
              "$ref": "#/definitions/TaskPriority"
            }
          ]
        },
        "request": {
          "description": "Original human request that created the task (Task Builder / Scan).",
          "type": [
            "string",
            "null"
          ]
        },
        "scope": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "status": {
          "default": "todo",
          "allOf": [
            {
              "$ref": "#/definitions/TaskStatus"
            }
          ]
        },
        "tags": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "title": {
          "type": "string"
        },
        "updated_at": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "TaskAgent": {
      "type": "object",
      "properties": {
        "followup_reasoning_effort": {
          "description": "Reasoning effort override for follow-up iterations (iterations > 1).",
          "anyOf": [
            {
              "$ref": "#/definitions/ReasoningEffort"
            },
            {
              "type": "null"
            }
          ]
        },
        "iterations": {
          "description": "Number of iterations to run for this task (overrides config).",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint8",
          "minimum": 1.0
        },
        "model": {
          "anyOf": [
            {
              "$ref": "#/definitions/Model"
            },
            {
              "type": "null"
            }
          ]
        },
        "model_effort": {
          "description": "Per-task reasoning effort override for Codex models. Default falls back to config.",
          "default": "default",
          "type": "string",
          "enum": [
            "default",
            "low",
            "medium",
            "high",
            "xhigh"
          ]
        },
        "runner": {
          "anyOf": [
            {
              "$ref": "#/definitions/Runner"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "TaskPriority": {
      "type": "string",
      "enum": [
        "critical",
        "high",
        "medium",
        "low"
      ]
    },
    "TaskStatus": {
      "type": "string",
      "enum": [
        "draft",
        "todo",
        "doing",
        "done",
        "rejected"
      ]
    }
  }
}
