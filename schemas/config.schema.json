{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Config",
  "description": "Root configuration struct for Ralph.",
  "type": "object",
  "properties": {
    "agent": {
      "description": "Agent runner defaults (Claude, Codex, OpenCode, Gemini, or Cursor).",
      "$ref": "#/$defs/AgentConfig",
      "default": {
        "ci_gate": {
          "argv": [
            "make",
            "ci"
          ],
          "enabled": true
        },
        "claude_bin": "claude",
        "claude_permission_mode": "bypass_permissions",
        "codex_bin": "codex",
        "cursor_bin": "agent",
        "followup_reasoning_effort": null,
        "gemini_bin": "gemini",
        "git_commit_push_enabled": true,
        "git_revert_mode": "ask",
        "instruction_files": null,
        "iterations": 1,
        "kimi_bin": "kimi",
        "model": "gpt-5.4",
        "notification": {
          "enabled": true,
          "notify_on_complete": true,
          "notify_on_fail": true,
          "notify_on_loop_complete": true,
          "sound_enabled": false,
          "sound_path": null,
          "suppress_when_active": true,
          "timeout_ms": 8000
        },
        "opencode_bin": "opencode",
        "phase_overrides": null,
        "phases": 3,
        "pi_bin": "pi",
        "reasoning_effort": "medium",
        "repoprompt_plan_required": false,
        "repoprompt_tool_injection": false,
        "runner": "codex",
        "runner_cli": {
          "defaults": {
            "approval_mode": "yolo",
            "output_format": "stream_json",
            "plan_mode": "default",
            "sandbox": "default",
            "unsupported_option_policy": "warn",
            "verbosity": "normal"
          },
          "runners": {
            "claude": {
              "approval_mode": null,
              "output_format": null,
              "plan_mode": null,
              "sandbox": null,
              "unsupported_option_policy": null,
              "verbosity": "verbose"
            },
            "codex": {
              "approval_mode": null,
              "output_format": null,
              "plan_mode": null,
              "sandbox": "disabled",
              "unsupported_option_policy": null,
              "verbosity": null
            },
            "kimi": {
              "approval_mode": "yolo",
              "output_format": null,
              "plan_mode": null,
              "sandbox": null,
              "unsupported_option_policy": null,
              "verbosity": null
            },
            "pi": {
              "approval_mode": "yolo",
              "output_format": null,
              "plan_mode": null,
              "sandbox": null,
              "unsupported_option_policy": null,
              "verbosity": null
            }
          }
        },
        "runner_retry": {
          "base_backoff_ms": null,
          "jitter_ratio": null,
          "max_attempts": null,
          "max_backoff_ms": null,
          "multiplier": null
        },
        "scan_prompt_version": "v2",
        "session_timeout_hours": 24,
        "webhook": {
          "enabled": null,
          "events": null,
          "parallel_queue_multiplier": null,
          "queue_capacity": null,
          "queue_policy": null,
          "retry_backoff_ms": null,
          "retry_count": null,
          "secret": null,
          "timeout_secs": null,
          "url": null
        }
      }
    },
    "loop": {
      "description": "Run loop waiting configuration (daemon/continuous mode).",
      "$ref": "#/$defs/LoopConfig",
      "default": {
        "empty_poll_ms": 30000,
        "notify_when_unblocked": false,
        "wait_poll_ms": 1000,
        "wait_timeout_seconds": 0,
        "wait_when_blocked": false,
        "wait_when_empty": false
      }
    },
    "parallel": {
      "description": "Parallel run-loop configuration.",
      "$ref": "#/$defs/ParallelConfig",
      "default": {
        "max_push_attempts": 50,
        "push_backoff_ms": [
          500,
          2000,
          5000,
          10000
        ],
        "workers": null,
        "workspace_retention_hours": 24,
        "workspace_root": null
      }
    },
    "plugins": {
      "description": "Plugin configuration (enable/disable + per-plugin settings).",
      "$ref": "#/$defs/PluginsConfig",
      "default": {
        "plugins": {}
      }
    },
    "profiles": {
      "description": "Optional named profiles for quick workflow switching.\n\nEach profile is an AgentConfig-shaped patch applied over `agent` when selected.\nProfile values override base config but are overridden by CLI flags and task.agent.",
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": {
        "$ref": "#/$defs/AgentConfig"
      }
    },
    "project_type": {
      "description": "\"code\" or \"docs\". Drives prompt defaults and small workflow decisions.",
      "anyOf": [
        {
          "$ref": "#/$defs/ProjectType"
        },
        {
          "type": "null"
        }
      ],
      "default": "code"
    },
    "queue": {
      "description": "Queue-related configuration.",
      "$ref": "#/$defs/QueueConfig",
      "default": {
        "aging_thresholds": {
          "rotten_days": 30,
          "stale_days": 14,
          "warning_days": 7
        },
        "auto_archive_terminal_after_days": null,
        "done_file": ".ralph/done.jsonc",
        "file": ".ralph/queue.jsonc",
        "id_prefix": "RQ",
        "id_width": 4,
        "max_dependency_depth": 10,
        "size_warning_threshold_kb": 500,
        "task_count_warning_threshold": 500
      }
    },
    "version": {
      "description": "Schema version for config.",
      "type": "integer",
      "format": "uint32",
      "default": 1,
      "minimum": 0
    }
  },
  "additionalProperties": false,
  "$defs": {
    "AgentConfig": {
      "description": "Agent runner defaults (Claude, Codex, OpenCode, Gemini, or Cursor).",
      "type": "object",
      "properties": {
        "ci_gate": {
          "description": "Structured CI gate execution settings.",
          "anyOf": [
            {
              "$ref": "#/$defs/CiGateConfig"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "claude_bin": {
          "description": "Override the claude executable name/path (default is \"claude\" if None).",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "claude_permission_mode": {
          "description": "Claude permission mode for tool and edit approval.\nAcceptEdits: auto-approves file edits only\nBypassPermissions: skip all permission prompts (YOLO mode)",
          "anyOf": [
            {
              "$ref": "#/$defs/ClaudePermissionMode"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "codex_bin": {
          "description": "Override the codex executable name/path (default is \"codex\" if None).",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "cursor_bin": {
          "description": "Override the cursor agent executable name/path (default is \"agent\" if None).\n\nNOTE: Cursor's runner binary name is `agent` (not `cursor`).",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "followup_reasoning_effort": {
          "description": "Reasoning effort override for follow-up iterations (iterations > 1).\nOnly meaningful for Codex models.",
          "anyOf": [
            {
              "$ref": "#/$defs/ReasoningEffort"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "gemini_bin": {
          "description": "Override the gemini executable name/path (default is \"gemini\" if None).",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "git_commit_push_enabled": {
          "description": "Enable automatic git commit and push after successful runs (default: true).",
          "type": [
            "boolean",
            "null"
          ],
          "default": null
        },
        "git_revert_mode": {
          "description": "Controls automatic git revert behavior when runner or supervision errors occur.",
          "anyOf": [
            {
              "$ref": "#/$defs/GitRevertMode"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "instruction_files": {
          "description": "Additional instruction files to inject at the top of every prompt sent to runner CLIs.\n\nPaths may be absolute, `~/`-prefixed, or repo-root relative. Missing files are treated as\nconfiguration errors. To include repo-local AGENTS.md, add `\"AGENTS.md\"` to this list.",
          "type": [
            "array",
            "null"
          ],
          "default": null,
          "items": {
            "type": "string"
          }
        },
        "iterations": {
          "description": "Number of iterations to run for each task (default: 1).",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint8",
          "default": null,
          "maximum": 255,
          "minimum": 1
        },
        "kimi_bin": {
          "description": "Override the kimi executable name/path (default is \"kimi\" if None).",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "model": {
          "description": "Default model.",
          "anyOf": [
            {
              "$ref": "#/$defs/Model"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "notification": {
          "description": "Desktop notification configuration for task completion.",
          "$ref": "#/$defs/NotificationConfig",
          "default": {
            "enabled": null,
            "notify_on_complete": null,
            "notify_on_fail": null,
            "notify_on_loop_complete": null,
            "sound_enabled": null,
            "sound_path": null,
            "suppress_when_active": null,
            "timeout_ms": null
          }
        },
        "opencode_bin": {
          "description": "Override the opencode executable name/path (default is \"opencode\" if None).",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "phase_overrides": {
          "description": "Per-phase overrides for runner, model, and reasoning effort.\n\nAllows specifying different settings for each phase (1, 2, 3).\nPhase-specific values override the global agent settings.",
          "anyOf": [
            {
              "$ref": "#/$defs/PhaseOverrides"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "phases": {
          "description": "Number of execution phases (1, 2, or 3).\n1 = single-pass, 2 = plan+implement, 3 = plan+implement+review.",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint8",
          "default": null,
          "maximum": 3,
          "minimum": 1
        },
        "pi_bin": {
          "description": "Override the pi executable name/path (default is \"pi\" if None).",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "reasoning_effort": {
          "description": "Default reasoning effort (only meaningful for Codex models).",
          "anyOf": [
            {
              "$ref": "#/$defs/ReasoningEffort"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "repoprompt_plan_required": {
          "description": "Require RepoPrompt usage during planning (inject context_builder instructions).",
          "type": [
            "boolean",
            "null"
          ],
          "default": null
        },
        "repoprompt_tool_injection": {
          "description": "Inject RepoPrompt tooling reminder block into prompts.",
          "type": [
            "boolean",
            "null"
          ],
          "default": null
        },
        "runner": {
          "description": "Which harness to use by default.",
          "anyOf": [
            {
              "$ref": "#/$defs/Runner"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "runner_cli": {
          "description": "Normalized runner CLI behavior overrides (output/approval/sandbox/etc).\n\nThis is additive: existing runner-specific fields remain supported.",
          "anyOf": [
            {
              "$ref": "#/$defs/RunnerCliConfigRoot"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "runner_retry": {
          "description": "Runner invocation retry/backoff configuration.",
          "$ref": "#/$defs/RunnerRetryConfig",
          "default": {
            "base_backoff_ms": null,
            "jitter_ratio": null,
            "max_attempts": null,
            "max_backoff_ms": null,
            "multiplier": null
          }
        },
        "scan_prompt_version": {
          "description": "Scan prompt version to use (v1 or v2, default: v2).",
          "anyOf": [
            {
              "$ref": "#/$defs/ScanPromptVersion"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "session_timeout_hours": {
          "description": "Session timeout in hours for crash recovery (default: 24).\nSessions older than this threshold are considered stale and require\nexplicit user confirmation to resume.",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "default": null,
          "minimum": 1
        },
        "webhook": {
          "description": "Webhook configuration for HTTP task event notifications.",
          "$ref": "#/$defs/WebhookConfig",
          "default": {
            "enabled": null,
            "events": null,
            "parallel_queue_multiplier": null,
            "queue_capacity": null,
            "queue_policy": null,
            "retry_backoff_ms": null,
            "retry_count": null,
            "secret": null,
            "timeout_secs": null,
            "url": null
          }
        }
      },
      "additionalProperties": false
    },
    "CiGateConfig": {
      "description": "Structured CI gate execution settings.",
      "type": "object",
      "properties": {
        "argv": {
          "description": "Direct argv execution. The first item is the program and remaining items are arguments.",
          "type": [
            "array",
            "null"
          ],
          "default": null,
          "items": {
            "type": "string"
          }
        },
        "enabled": {
          "description": "Enable or disable the CI gate entirely.",
          "type": [
            "boolean",
            "null"
          ],
          "default": null
        }
      },
      "additionalProperties": false
    },
    "ClaudePermissionMode": {
      "type": "string",
      "enum": [
        "accept_edits",
        "bypass_permissions"
      ]
    },
    "GitRevertMode": {
      "description": "Git revert mode for handling runner/supervision errors.",
      "type": "string",
      "enum": [
        "ask",
        "enabled",
        "disabled"
      ]
    },
    "LoopConfig": {
      "description": "Run loop waiting configuration for daemon/continuous mode.",
      "type": "object",
      "properties": {
        "empty_poll_ms": {
          "description": "Poll interval in milliseconds while waiting for new tasks when queue is empty.\nDefault: 30000 (30 seconds). Minimum: 50.",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "default": null,
          "minimum": 50
        },
        "notify_when_unblocked": {
          "description": "Send notification when queue transitions from blocked to runnable.",
          "type": [
            "boolean",
            "null"
          ],
          "default": null
        },
        "wait_poll_ms": {
          "description": "Poll interval in milliseconds while waiting for blocked tasks to become runnable.\nDefault: 1000 (1 second). Minimum: 50.",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "default": null,
          "minimum": 50
        },
        "wait_timeout_seconds": {
          "description": "Timeout in seconds for waiting (0 = no timeout).",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "default": null,
          "minimum": 0
        },
        "wait_when_blocked": {
          "description": "Wait when blocked by dependencies/schedule instead of exiting.",
          "type": [
            "boolean",
            "null"
          ],
          "default": null
        },
        "wait_when_empty": {
          "description": "Wait when queue is empty instead of exiting (continuous/daemon mode).",
          "type": [
            "boolean",
            "null"
          ],
          "default": null
        }
      },
      "additionalProperties": false
    },
    "Model": {
      "oneOf": [
        {
          "description": "OpenAI GPT-5.4 (default Codex model)",
          "type": "string",
          "const": "gpt-5.4"
        },
        {
          "description": "OpenAI GPT-5.3 Codex",
          "type": "string",
          "const": "gpt-5.3-codex"
        },
        {
          "description": "OpenAI GPT-5.3 Codex Spark (fast)",
          "type": "string",
          "const": "gpt-5.3-codex-spark"
        },
        {
          "description": "OpenAI GPT-5.3",
          "type": "string",
          "const": "gpt-5.3"
        },
        {
          "description": "ZhipuAI GLM-4.7",
          "type": "string",
          "const": "zai-coding-plan/glm-4.7"
        },
        {
          "description": "Custom model identifier",
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "NotificationConfig": {
      "description": "Desktop notification configuration.",
      "type": "object",
      "properties": {
        "enabled": {
          "description": "Enable desktop notifications on task completion (default: true).\nThis is the legacy/compatibility field; prefer `notify_on_complete`.",
          "type": [
            "boolean",
            "null"
          ],
          "default": null
        },
        "notify_on_complete": {
          "description": "Enable desktop notifications on task completion (default: true).",
          "type": [
            "boolean",
            "null"
          ],
          "default": null
        },
        "notify_on_fail": {
          "description": "Enable desktop notifications on task failure (default: true).",
          "type": [
            "boolean",
            "null"
          ],
          "default": null
        },
        "notify_on_loop_complete": {
          "description": "Enable desktop notifications when loop mode completes (default: true).",
          "type": [
            "boolean",
            "null"
          ],
          "default": null
        },
        "sound_enabled": {
          "description": "Enable sound alerts with notifications (default: false).",
          "type": [
            "boolean",
            "null"
          ],
          "default": null
        },
        "sound_path": {
          "description": "Custom sound file path (platform-specific format).\nIf not set, uses platform default sounds.",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "suppress_when_active": {
          "description": "Suppress notifications when a foreground UI client is active (default: true).",
          "type": [
            "boolean",
            "null"
          ],
          "default": null
        },
        "timeout_ms": {
          "description": "Notification timeout in milliseconds (default: 8000).",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "default": null,
          "maximum": 60000,
          "minimum": 1000
        }
      },
      "additionalProperties": false
    },
    "ParallelConfig": {
      "description": "Parallel run-loop configuration.",
      "type": "object",
      "properties": {
        "max_push_attempts": {
          "description": "Maximum number of push attempts before giving up.",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint8",
          "default": null,
          "maximum": 255,
          "minimum": 1
        },
        "push_backoff_ms": {
          "description": "Backoff intervals in milliseconds for push retries.",
          "type": [
            "array",
            "null"
          ],
          "default": null,
          "items": {
            "type": "integer",
            "format": "uint64",
            "minimum": 0
          }
        },
        "workers": {
          "description": "Number of workers to run concurrently when parallel mode is enabled.",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint8",
          "default": null,
          "maximum": 255,
          "minimum": 2
        },
        "workspace_retention_hours": {
          "description": "Hours to retain blocked workspaces before cleanup.",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "default": null,
          "minimum": 1
        },
        "workspace_root": {
          "description": "Root directory for parallel workspaces (relative to repo root if not absolute).",
          "type": [
            "string",
            "null"
          ],
          "default": null
        }
      },
      "additionalProperties": false
    },
    "PhaseOverrideConfig": {
      "description": "Per-phase configuration overrides for runner, model, and reasoning effort.\n\nAll fields are optional to support leaf-wise merging:\n- `Some(value)` overrides the parent config\n- `None` means \"inherit from parent\"",
      "type": "object",
      "properties": {
        "model": {
          "description": "Model to use for this phase (overrides global agent.model)",
          "anyOf": [
            {
              "$ref": "#/$defs/Model"
            },
            {
              "type": "null"
            }
          ]
        },
        "reasoning_effort": {
          "description": "Reasoning effort for this phase (overrides global agent.reasoning_effort)",
          "anyOf": [
            {
              "$ref": "#/$defs/ReasoningEffort"
            },
            {
              "type": "null"
            }
          ]
        },
        "runner": {
          "description": "Runner to use for this phase (overrides global agent.runner)",
          "anyOf": [
            {
              "$ref": "#/$defs/Runner"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "PhaseOverrides": {
      "description": "Phase overrides container for Phase 1/2/3 execution.\n\nPer-phase configuration for Phase 1/2/3 execution.\n\nInvariants/assumptions:\n- Overrides are defined per phase only; there is no shared `defaults` layer inside\n  `agent.phase_overrides`. Use global `agent.runner` / `agent.model` /\n  `agent.reasoning_effort` for shared defaults.\n- Merging is leaf-wise: `Some(value)` overrides, `None` inherits.",
      "type": "object",
      "properties": {
        "phase1": {
          "description": "Phase 1 specific overrides",
          "anyOf": [
            {
              "$ref": "#/$defs/PhaseOverrideConfig"
            },
            {
              "type": "null"
            }
          ]
        },
        "phase2": {
          "description": "Phase 2 specific overrides",
          "anyOf": [
            {
              "$ref": "#/$defs/PhaseOverrideConfig"
            },
            {
              "type": "null"
            }
          ]
        },
        "phase3": {
          "description": "Phase 3 specific overrides",
          "anyOf": [
            {
              "$ref": "#/$defs/PhaseOverrideConfig"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "PluginConfig": {
      "description": "Per-plugin configuration.",
      "type": "object",
      "properties": {
        "config": {
          "description": "Opaque plugin configuration blob (passed through to the plugin).",
          "default": null
        },
        "enabled": {
          "description": "Enable/disable the plugin. If None, defaults to disabled.",
          "type": [
            "boolean",
            "null"
          ],
          "default": null
        }
      },
      "additionalProperties": false
    },
    "PluginsConfig": {
      "description": "Plugin configuration container.",
      "type": "object",
      "properties": {
        "plugins": {
          "description": "Per-plugin configuration keyed by plugin id.",
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/PluginConfig"
          },
          "default": {}
        }
      },
      "additionalProperties": false
    },
    "ProjectType": {
      "description": "Project type classification.",
      "type": "string",
      "enum": [
        "code",
        "docs"
      ]
    },
    "QueueAgingThresholds": {
      "description": "Aging threshold configuration for `ralph queue aging`.\n\nControls the day thresholds for categorizing tasks by age.\nOrdering invariant: warning_days < stale_days < rotten_days",
      "type": "object",
      "properties": {
        "rotten_days": {
          "description": "Mark as rotten when age is strictly greater than this many days.",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "default": null,
          "maximum": 3650,
          "minimum": 0
        },
        "stale_days": {
          "description": "Mark as stale when age is strictly greater than this many days.",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "default": null,
          "maximum": 3650,
          "minimum": 0
        },
        "warning_days": {
          "description": "Warn when task age is strictly greater than this many days.",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "default": null,
          "maximum": 3650,
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "QueueConfig": {
      "description": "Queue-related configuration.",
      "type": "object",
      "properties": {
        "aging_thresholds": {
          "description": "Thresholds for `ralph queue aging` buckets.\n\nDefault: warning>7d, stale>14d, rotten>30d.\nOrdering must satisfy: warning_days < stale_days < rotten_days.",
          "anyOf": [
            {
              "$ref": "#/$defs/QueueAgingThresholds"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "auto_archive_terminal_after_days": {
          "description": "Auto-archive terminal tasks (done/rejected) from queue to done after this many days.\n\nSemantics:\n- None: disabled (default)\n- Some(0): archive immediately when the sweep runs\n- Some(N): archive when completed_at is at least N days old\n\nThe sweep runs after selected queue mutation operations (e.g., task edits and run supervision).\nTasks with missing or invalid completed_at timestamps are not moved when N > 0.",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "default": null,
          "maximum": 3650,
          "minimum": 0
        },
        "done_file": {
          "description": "Path to the JSON done archive file, relative to repo root.\n\nPaths are intended to be repo-root relative. Parallel mode requires the\nresolved path to be under the repo root (no `..`) so it can be copied\ninto workspace clones.",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "file": {
          "description": "Path to the JSON queue file, relative to repo root.\n\nPaths are intended to be repo-root relative. Parallel mode requires the\nresolved path to be under the repo root (no `..`) so it can be copied\ninto workspace clones.",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "id_prefix": {
          "description": "ID prefix (default: \"RQ\").",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "id_width": {
          "description": "Zero pad width for the numeric suffix (default: 4 -> RQ-0001).",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint8",
          "default": null,
          "maximum": 255,
          "minimum": 1
        },
        "max_dependency_depth": {
          "description": "Maximum allowed dependency chain depth before warning (default: 10).",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint8",
          "default": null,
          "maximum": 100,
          "minimum": 1
        },
        "size_warning_threshold_kb": {
          "description": "Warning threshold for queue file size in KB (default: 500).",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "default": null,
          "maximum": 10000,
          "minimum": 100
        },
        "task_count_warning_threshold": {
          "description": "Warning threshold for number of tasks in queue (default: 500).",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "default": null,
          "maximum": 5000,
          "minimum": 50
        }
      },
      "additionalProperties": false
    },
    "ReasoningEffort": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "xhigh"
      ]
    },
    "Runner": {
      "description": "Runner id (built-ins: codex, opencode, gemini, cursor, claude, kimi, pi; plugin runners: any other non-empty string)",
      "type": "string",
      "examples": [
        "claude",
        "acme.super_runner"
      ]
    },
    "RunnerApprovalMode": {
      "oneOf": [
        {
          "description": "Do not apply any approval flags; runner defaults apply.",
          "type": "string",
          "const": "default"
        },
        {
          "description": "Attempt to auto-approve edits but not all tool actions (runner-specific).",
          "type": "string",
          "const": "auto_edits"
        },
        {
          "description": "Bypass approvals / run headless (runner-specific).",
          "type": "string",
          "const": "yolo"
        },
        {
          "description": "Strict safety mode. Warning: some runners may become interactive and hang.",
          "type": "string",
          "const": "safe"
        }
      ]
    },
    "RunnerCliConfigRoot": {
      "type": "object",
      "properties": {
        "defaults": {
          "description": "Default normalized runner CLI options applied to all runners (unless overridden).",
          "$ref": "#/$defs/RunnerCliOptionsPatch",
          "default": {
            "approval_mode": null,
            "output_format": null,
            "plan_mode": null,
            "sandbox": null,
            "unsupported_option_policy": null,
            "verbosity": null
          }
        },
        "runners": {
          "description": "Optional per-runner overrides, merged leaf-wise over `defaults`.",
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/RunnerCliOptionsPatch"
          },
          "default": {}
        }
      },
      "additionalProperties": false
    },
    "RunnerCliOptionsPatch": {
      "type": "object",
      "properties": {
        "approval_mode": {
          "description": "Desired approval/permission behavior.",
          "anyOf": [
            {
              "$ref": "#/$defs/RunnerApprovalMode"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "output_format": {
          "description": "Desired output format for runner execution.",
          "anyOf": [
            {
              "$ref": "#/$defs/RunnerOutputFormat"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "plan_mode": {
          "description": "Desired plan/read-only behavior (when supported by the runner).",
          "anyOf": [
            {
              "$ref": "#/$defs/RunnerPlanMode"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "sandbox": {
          "description": "Desired sandbox behavior (when supported by the runner).",
          "anyOf": [
            {
              "$ref": "#/$defs/RunnerSandboxMode"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "unsupported_option_policy": {
          "description": "Policy for unsupported options (warn/error/ignore).",
          "anyOf": [
            {
              "$ref": "#/$defs/UnsupportedOptionPolicy"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "verbosity": {
          "description": "Desired verbosity (when supported by the runner).",
          "anyOf": [
            {
              "$ref": "#/$defs/RunnerVerbosity"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "additionalProperties": false
    },
    "RunnerOutputFormat": {
      "oneOf": [
        {
          "description": "Newline-delimited JSON objects (required for Ralph's streaming parser).",
          "type": "string",
          "const": "stream_json"
        },
        {
          "description": "JSON output (may not be streaming; currently treated as unsupported by Ralph execution).",
          "type": "string",
          "const": "json"
        },
        {
          "description": "Plain text output (currently treated as unsupported by Ralph execution).",
          "type": "string",
          "const": "text"
        }
      ]
    },
    "RunnerPlanMode": {
      "type": "string",
      "enum": [
        "default",
        "enabled",
        "disabled"
      ]
    },
    "RunnerRetryConfig": {
      "description": "Runner retry/backoff configuration for transient failure handling.\n\nControls automatic retry behavior when runner invocations fail with\ntransient errors (rate limits, temporary unavailability, network issues).\nDistinct from webhook retry settings (`agent.webhook.retry_*`).",
      "type": "object",
      "properties": {
        "base_backoff_ms": {
          "description": "Base backoff in milliseconds. Default: 1000.",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "default": null,
          "maximum": 600000,
          "minimum": 0
        },
        "jitter_ratio": {
          "description": "Jitter ratio in \\[0,1\\]. Default: 0.2 (20% variance).",
          "type": [
            "number",
            "null"
          ],
          "format": "double",
          "default": null,
          "maximum": 1.0,
          "minimum": 0.0
        },
        "max_attempts": {
          "description": "Total attempts (including initial). Default: 3.",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "default": null,
          "maximum": 20,
          "minimum": 1
        },
        "max_backoff_ms": {
          "description": "Max backoff cap in milliseconds. Default: 30000.",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "default": null,
          "maximum": 600000,
          "minimum": 0
        },
        "multiplier": {
          "description": "Exponential multiplier. Default: 2.0.",
          "type": [
            "number",
            "null"
          ],
          "format": "double",
          "default": null,
          "maximum": 10.0,
          "minimum": 1.0
        }
      },
      "additionalProperties": false
    },
    "RunnerSandboxMode": {
      "type": "string",
      "enum": [
        "default",
        "enabled",
        "disabled"
      ]
    },
    "RunnerVerbosity": {
      "type": "string",
      "enum": [
        "quiet",
        "normal",
        "verbose"
      ]
    },
    "ScanPromptVersion": {
      "description": "Scan prompt version to use for scan operations.",
      "oneOf": [
        {
          "description": "Version 1: Original rule-based scan prompts with fixed minimum task counts.",
          "type": "string",
          "const": "v1"
        },
        {
          "description": "Version 2: Rubric-based scan prompts with quality-focused STOP CONDITION (default).",
          "type": "string",
          "const": "v2"
        }
      ]
    },
    "UnsupportedOptionPolicy": {
      "type": "string",
      "enum": [
        "ignore",
        "warn",
        "error"
      ]
    },
    "WebhookConfig": {
      "description": "Webhook configuration for HTTP task event notifications.",
      "type": "object",
      "properties": {
        "enabled": {
          "description": "Enable webhook notifications (default: false).",
          "type": [
            "boolean",
            "null"
          ],
          "default": null
        },
        "events": {
          "description": "Events to subscribe to (default: legacy task events only).",
          "type": [
            "array",
            "null"
          ],
          "default": null,
          "items": {
            "$ref": "#/$defs/WebhookEventSubscription"
          }
        },
        "parallel_queue_multiplier": {
          "description": "Multiplier for queue capacity in parallel mode (default: 2.0, range: 1.0-10.0).\nWhen running with N parallel workers, effective capacity = queue_capacity * max(1, workers * multiplier).\nSet higher (e.g., 3.0) if webhook endpoint is slow or unreliable.",
          "type": [
            "number",
            "null"
          ],
          "format": "float",
          "default": null,
          "maximum": 10.0,
          "minimum": 1.0
        },
        "queue_capacity": {
          "description": "Maximum number of pending webhooks in the delivery queue (default: 500, range: 10-10000).",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "default": null,
          "maximum": 10000,
          "minimum": 10
        },
        "queue_policy": {
          "description": "Backpressure policy when queue is full (default: drop_oldest).\n- drop_oldest: Drop new webhooks when full (preserves existing queue contents)\n- drop_new: Drop the new webhook if queue is full\n- block_with_timeout: Block sender briefly (100ms), then drop if still full",
          "anyOf": [
            {
              "$ref": "#/$defs/WebhookQueuePolicy"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "retry_backoff_ms": {
          "description": "Retry backoff base in milliseconds (default: 1000, max: 30000).",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "default": null,
          "maximum": 30000,
          "minimum": 100
        },
        "retry_count": {
          "description": "Number of retry attempts for failed deliveries (default: 3, max: 10).",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "default": null,
          "maximum": 10,
          "minimum": 0
        },
        "secret": {
          "description": "Secret key for HMAC-SHA256 signature generation.\nWhen set, webhooks include an X-Ralph-Signature header.",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "timeout_secs": {
          "description": "Request timeout in seconds (default: 30, max: 300).",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "default": null,
          "maximum": 300,
          "minimum": 1
        },
        "url": {
          "description": "Webhook endpoint URL (required when enabled).",
          "type": [
            "string",
            "null"
          ],
          "default": null
        }
      },
      "additionalProperties": false
    },
    "WebhookEventSubscription": {
      "description": "Webhook event subscription type for config.\nEach variant corresponds to a WebhookEventType, plus Wildcard for \"all events\".",
      "oneOf": [
        {
          "description": "Task was created/added to queue.",
          "type": "string",
          "const": "task_created"
        },
        {
          "description": "Task status changed to Doing (execution started).",
          "type": "string",
          "const": "task_started"
        },
        {
          "description": "Task completed successfully (status Done).",
          "type": "string",
          "const": "task_completed"
        },
        {
          "description": "Task failed or was rejected.",
          "type": "string",
          "const": "task_failed"
        },
        {
          "description": "Generic status change.",
          "type": "string",
          "const": "task_status_changed"
        },
        {
          "description": "Run loop started.",
          "type": "string",
          "const": "loop_started"
        },
        {
          "description": "Run loop stopped.",
          "type": "string",
          "const": "loop_stopped"
        },
        {
          "description": "Phase started for a task.",
          "type": "string",
          "const": "phase_started"
        },
        {
          "description": "Phase completed for a task.",
          "type": "string",
          "const": "phase_completed"
        },
        {
          "description": "Queue became unblocked.",
          "type": "string",
          "const": "queue_unblocked"
        },
        {
          "description": "Wildcard: subscribe to all events.",
          "type": "string",
          "const": "*"
        }
      ]
    },
    "WebhookQueuePolicy": {
      "description": "Backpressure policy for webhook delivery queue.",
      "oneOf": [
        {
          "description": "Drop new webhooks when queue is full, preserving existing queue contents.\nThis is functionally equivalent to `drop_new` due to channel constraints.",
          "type": "string",
          "const": "drop_oldest"
        },
        {
          "description": "Drop the new webhook if queue is full.",
          "type": "string",
          "const": "drop_new"
        },
        {
          "description": "Block sender briefly, then drop if queue is still full.",
          "type": "string",
          "const": "block_with_timeout"
        }
      ]
    }
  }
}
