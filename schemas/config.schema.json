    "WebhookConfig": {
      "description": "Webhook configuration for HTTP task event notifications.",
      "type": "object",
      "properties": {
        "enabled": {
          "description": "Enable webhook notifications (default: false).",
          "default": null,
          "type": [
            "boolean",
            "null"
          ]
        },
        "events": {
          "description": "Events to subscribe to (default: legacy task events only). Supported: task_created, task_started, task_completed, task_failed, task_status_changed, loop_started, loop_stopped, phase_started, phase_completed Note: loop_* and phase_* events are opt-in and require explicit configuration. Use [\"*\"] to subscribe to all events.",
          "default": null,
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "queue_capacity": {
          "description": "Maximum number of pending webhooks in the delivery queue (default: 100, range: 10-10000).",
          "default": null,
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "maximum": 10000.0,
          "minimum": 10.0
        },
        "queue_policy": {
          "description": "Backpressure policy when queue is full (default: drop_oldest). - drop_oldest: Drop new webhooks when full (preserves existing queue contents) - drop_new: Drop the new webhook if queue is full - block_with_timeout: Block sender briefly (100ms), then drop if still full",
          "default": null,
          "anyOf": [
            {
              "$ref": "#/definitions/WebhookQueuePolicy"
            },
            {
              "type": "null"
            }
          ]
        },
        "retry_backoff_ms": {
          "description": "Retry backoff base in milliseconds (default: 1000, max: 30000).",
          "default": null,
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "maximum": 30000.0,
          "minimum": 100.0
        },
        "retry_count": {
          "description": "Number of retry attempts for failed deliveries (default: 3, max: 10).",
          "default": null,
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "maximum": 10.0,
          "minimum": 0.0
        },
        "secret": {
          "description": "Secret key for HMAC-SHA256 signature generation. When set, webhooks include an X-Ralph-Signature header.",
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "timeout_secs": {
          "description": "Request timeout in seconds (default: 30, max: 300).",
          "default": null,
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "maximum": 300.0,
          "minimum": 1.0
        },
        "url": {
          "description": "Webhook endpoint URL (required when enabled).",
          "default": null,
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "WebhookQueuePolicy": {
      "description": "Backpressure policy for webhook delivery queue.",
      "oneOf": [
        {
          "description": "Drop new webhooks when queue is full, preserving existing queue contents. This is functionally equivalent to `drop_new` due to channel constraints.",
          "type": "string",
          "enum": [
            "drop_oldest"
          ]
        },
        {
          "description": "Drop the new webhook if queue is full.",
          "type": "string",
          "enum": [
            "drop_new"
          ]
        },
        {
          "description": "Block sender briefly, then drop if queue is still full.",
          "type": "string",
          "enum": [
            "block_with_timeout"
          ]
        }
      ]
    }
