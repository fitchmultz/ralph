              "$ref": "#/definitions/QueueAgingThresholds"
            },
            {
              "type": "null"
            }
          ]
        },
        "auto_archive_terminal_after_days": {
          "description": "Auto-archive terminal tasks (done/rejected) from queue to done after this many days.\n\nSemantics: - None: disabled (default) - Some(0): archive immediately when the sweep runs - Some(N): archive when completed_at is at least N days old\n\nThe sweep runs during TUI startup/reload and after CLI task edit operations. Tasks with missing or invalid completed_at timestamps are not moved when N > 0.",
          "default": null,
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "maximum": 3650.0,
          "minimum": 0.0
        },
        "done_file": {
          "description": "Path to the JSON done archive file, relative to repo root.\n\nPaths are intended to be repo-root relative. Parallel mode requires the resolved path to be under the repo root (no `..`) so it can be copied into workspace clones.",
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "file": {
          "description": "Path to the JSON queue file, relative to repo root.\n\nPaths are intended to be repo-root relative. Parallel mode requires the resolved path to be under the repo root (no `..`) so it can be copied into workspace clones.",
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "id_prefix": {
          "description": "ID prefix (default: \"RQ\").",
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "id_width": {
          "description": "Zero pad width for the numeric suffix (default: 4 -> RQ-0001).",
          "default": null,
          "type": [
            "integer",
            "null"
          ],
          "format": "uint8",
          "minimum": 0.0
        },
        "max_dependency_depth": {
          "description": "Maximum allowed dependency chain depth before warning (default: 10).",
          "default": null,
          "type": [
            "integer",
            "null"
          ],
          "format": "uint8",
          "maximum": 100.0,
          "minimum": 1.0
        },
        "size_warning_threshold_kb": {
          "description": "Warning threshold for queue file size in KB (default: 500).",
          "default": null,
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "maximum": 10000.0,
          "minimum": 100.0
        },
        "task_count_warning_threshold": {
          "description": "Warning threshold for number of tasks in queue (default: 500).",
          "default": null,
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "maximum": 5000.0,
          "minimum": 50.0
        }
