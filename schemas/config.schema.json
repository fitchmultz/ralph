{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Config",
  "type": "object",
  "properties": {
    "agent": {
      "description": "Agent runner defaults (Claude, Codex, OpenCode, Gemini, or Cursor).",
      "default": {
        "ci_gate_command": "make ci",
        "ci_gate_enabled": true,
        "claude_bin": "claude",
        "claude_permission_mode": "bypass_permissions",
        "codex_bin": "codex",
        "cursor_bin": "agent",
        "followup_reasoning_effort": null,
        "gemini_bin": "gemini",
        "git_commit_push_enabled": true,
        "git_revert_mode": "ask",
        "instruction_files": null,
        "iterations": 1,
        "kimi_bin": "kimi",
        "model": "sonnet",
        "notification": {
          "enabled": true,
          "sound_enabled": false,
          "sound_path": null,
          "timeout_ms": 8000
        },
        "opencode_bin": "opencode",
        "phases": 3,
        "pi_bin": "pi",
        "reasoning_effort": "medium",
        "repoprompt_plan_required": false,
        "repoprompt_tool_injection": false,
        "runner": "claude",
        "runner_cli": {
          "defaults": {
            "approval_mode": "yolo",
            "output_format": "stream_json",
            "plan_mode": "default",
            "sandbox": "default",
            "unsupported_option_policy": "warn",
            "verbosity": "normal"
          },
          "runners": {
            "claude": {
              "approval_mode": null,
              "output_format": null,
              "plan_mode": null,
              "sandbox": null,
              "unsupported_option_policy": null,
              "verbosity": "verbose"
            },
            "codex": {
              "approval_mode": null,
              "output_format": null,
              "plan_mode": null,
              "sandbox": "disabled",
              "unsupported_option_policy": null,
              "verbosity": null
            },
            "kimi": {
              "approval_mode": "yolo",
              "output_format": null,
              "plan_mode": null,
              "sandbox": null,
              "unsupported_option_policy": null,
              "verbosity": null
            },
            "pi": {
              "approval_mode": "yolo",
              "output_format": null,
              "plan_mode": null,
              "sandbox": null,
              "unsupported_option_policy": null,
              "verbosity": null
            }
          }
        },
        "update_task_before_run": false
      },
      "allOf": [
        {
          "$ref": "#/definitions/AgentConfig"
        }
      ]
    },
    "project_type": {
      "description": "\"code\" or \"docs\". Drives prompt defaults and small workflow decisions.",
      "default": "code",
      "anyOf": [
        {
          "$ref": "#/definitions/ProjectType"
        },
        {
          "type": "null"
        }
      ]
    },
    "queue": {
      "description": "Queue-related configuration.",
      "default": {
        "done_file": ".ralph/done.json",
        "file": ".ralph/queue.json",
        "id_prefix": "RQ",
        "id_width": 4
      },
      "allOf": [
        {
          "$ref": "#/definitions/QueueConfig"
        }
      ]
    },
    "tui": {
      "description": "TUI-specific configuration.",
      "default": {
        "auto_archive_terminal": null
      },
      "allOf": [
        {
          "$ref": "#/definitions/TuiConfig"
        }
      ]
    },
    "version": {
      "description": "Schema version for config.",
      "default": 1,
      "type": "integer",
      "format": "uint32",
      "minimum": 0.0
    }
  },
  "additionalProperties": false,
  "definitions": {
    "AgentConfig": {
      "type": "object",
      "properties": {
        "ci_gate_command": {
          "description": "CI gate command to run (default: \"make ci\").",
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "ci_gate_enabled": {
          "description": "Enable or disable the CI gate entirely (default: true).",
          "default": null,
          "type": [
            "boolean",
            "null"
          ]
        },
        "claude_bin": {
          "description": "Override the claude executable name/path (default is \"claude\" if None).",
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "claude_permission_mode": {
          "description": "Claude permission mode for tool and edit approval. AcceptEdits: auto-approves file edits only BypassPermissions: skip all permission prompts (YOLO mode)",
          "default": null,
          "anyOf": [
            {
              "$ref": "#/definitions/ClaudePermissionMode"
            },
            {
              "type": "null"
            }
          ]
        },
        "codex_bin": {
          "description": "Override the codex executable name/path (default is \"codex\" if None).",
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "cursor_bin": {
          "description": "Override the cursor agent executable name/path (default is \"agent\" if None).\n\nNOTE: Cursor's runner binary name is `agent` (not `cursor`).",
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "followup_reasoning_effort": {
          "description": "Reasoning effort override for follow-up iterations (iterations > 1). Only meaningful for Codex models.",
          "default": null,
          "anyOf": [
            {
              "$ref": "#/definitions/ReasoningEffort"
            },
            {
              "type": "null"
            }
          ]
        },
        "gemini_bin": {
          "description": "Override the gemini executable name/path (default is \"gemini\" if None).",
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "git_commit_push_enabled": {
          "description": "Enable automatic git commit and push after successful runs (default: true).",
          "default": null,
          "type": [
            "boolean",
            "null"
          ]
        },
        "git_revert_mode": {
          "description": "Controls automatic git revert behavior when runner or supervision errors occur.",
          "default": null,
          "anyOf": [
            {
              "$ref": "#/definitions/GitRevertMode"
            },
            {
              "type": "null"
            }
          ]
        },
        "instruction_files": {
          "description": "Additional instruction files to inject at the top of every prompt sent to runner CLIs.\n\nPaths may be absolute, `~/`-prefixed, or repo-root relative. Missing files are treated as configuration errors.\n\nNOTE: `AGENTS.md` at the repo root is injected automatically when present.",
          "default": null,
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "iterations": {
          "description": "Number of iterations to run for each task (default: 1).",
          "default": null,
          "type": [
            "integer",
            "null"
          ],
          "format": "uint8",
          "minimum": 1.0
        },
        "kimi_bin": {
          "description": "Override the kimi executable name/path (default is \"kimi\" if None).",
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "model": {
          "description": "Default model.",
          "default": null,
          "anyOf": [
            {
              "$ref": "#/definitions/Model"
            },
            {
              "type": "null"
            }
          ]
        },
        "notification": {
          "description": "Desktop notification configuration for task completion.",
          "default": {
            "enabled": null,
            "sound_enabled": null,
            "sound_path": null,
            "timeout_ms": null
          },
          "allOf": [
            {
              "$ref": "#/definitions/NotificationConfig"
            }
          ]
        },
        "opencode_bin": {
          "description": "Override the opencode executable name/path (default is \"opencode\" if None).",
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "phases": {
          "description": "Number of execution phases (1, 2, or 3). 1 = single-pass, 2 = plan+implement, 3 = plan+implement+review.",
          "default": null,
          "type": [
            "integer",
            "null"
          ],
          "format": "uint8",
          "maximum": 3.0,
          "minimum": 1.0
        },
        "pi_bin": {
          "description": "Override the pi executable name/path (default is \"pi\" if None).",
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "reasoning_effort": {
          "description": "Default reasoning effort (only meaningful for Codex models).",
          "default": null,
          "anyOf": [
            {
              "$ref": "#/definitions/ReasoningEffort"
            },
            {
              "type": "null"
            }
          ]
        },
        "repoprompt_plan_required": {
          "description": "Require RepoPrompt usage during planning (inject context_builder instructions).",
          "default": null,
          "type": [
            "boolean",
            "null"
          ]
        },
        "repoprompt_tool_injection": {
          "description": "Inject RepoPrompt tooling reminder block into prompts.",
          "default": null,
          "type": [
            "boolean",
            "null"
          ]
        },
        "runner": {
          "description": "Which harness to use by default.",
          "default": null,
          "anyOf": [
            {
              "$ref": "#/definitions/Runner"
            },
            {
              "type": "null"
            }
          ]
        },
        "runner_cli": {
          "description": "Normalized runner CLI behavior overrides (output/approval/sandbox/etc).\n\nThis is additive: existing runner-specific fields remain supported.",
          "default": null,
          "anyOf": [
            {
              "$ref": "#/definitions/RunnerCliConfigRoot"
            },
            {
              "type": "null"
            }
          ]
        },
        "update_task_before_run": {
          "description": "If true, automatically run `ralph task update <TASK_ID>` once per task immediately before the supervisor marks the task as `doing` and starts execution.\n\nDefault: false (opt-in).",
          "default": null,
          "type": [
            "boolean",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "AutoArchiveBehavior": {
      "description": "Behavior for auto-archiving terminal tasks (Done/Rejected) when set via TUI.",
      "oneOf": [
        {
          "description": "Never auto-archive (current behavior).",
          "type": "string",
          "enum": [
            "never"
          ]
        },
        {
          "description": "Ask before archiving.",
          "type": "string",
          "enum": [
            "prompt"
          ]
        },
        {
          "description": "Archive immediately without prompt.",
          "type": "string",
          "enum": [
            "always"
          ]
        }
      ]
    },
    "ClaudePermissionMode": {
      "type": "string",
      "enum": [
        "accept_edits",
        "bypass_permissions"
      ]
    },
    "GitRevertMode": {
      "type": "string",
      "enum": [
        "ask",
        "enabled",
        "disabled"
      ]
    },
    "Model": {
      "type": "string"
    },
    "NotificationConfig": {
      "description": "Desktop notification configuration.",
      "type": "object",
      "properties": {
        "enabled": {
          "description": "Enable desktop notifications on task completion (default: true).",
          "default": null,
          "type": [
            "boolean",
            "null"
          ]
        },
        "sound_enabled": {
          "description": "Enable sound alerts with notifications (default: false).",
          "default": null,
          "type": [
            "boolean",
            "null"
          ]
        },
        "sound_path": {
          "description": "Custom sound file path (platform-specific format). If not set, uses platform default sounds.",
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "timeout_ms": {
          "description": "Notification timeout in milliseconds (default: 8000).",
          "default": null,
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "maximum": 60000.0,
          "minimum": 1000.0
        }
      },
      "additionalProperties": false
    },
    "ProjectType": {
      "type": "string",
      "enum": [
        "code",
        "docs"
      ]
    },
    "QueueConfig": {
      "type": "object",
      "properties": {
        "done_file": {
          "description": "Path to the JSON done archive file, relative to repo root.",
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "file": {
          "description": "Path to the JSON queue file, relative to repo root.",
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "id_prefix": {
          "description": "ID prefix (default: \"RQ\").",
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "id_width": {
          "description": "Zero pad width for the numeric suffix (default: 4 -> RQ-0001).",
          "default": null,
          "type": [
            "integer",
            "null"
          ],
          "format": "uint8",
          "minimum": 0.0
        }
      },
      "additionalProperties": false
    },
    "ReasoningEffort": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "xhigh"
      ]
    },
    "Runner": {
      "type": "string",
      "enum": [
        "codex",
        "opencode",
        "gemini",
        "cursor",
        "claude",
        "kimi",
        "pi"
      ]
    },
    "RunnerApprovalMode": {
      "oneOf": [
        {
          "description": "Do not apply any approval flags; runner defaults apply.",
          "type": "string",
          "enum": [
            "default"
          ]
        },
        {
          "description": "Attempt to auto-approve edits but not all tool actions (runner-specific).",
          "type": "string",
          "enum": [
            "auto_edits"
          ]
        },
        {
          "description": "Bypass approvals / run headless (runner-specific).",
          "type": "string",
          "enum": [
            "yolo"
          ]
        },
        {
          "description": "Strict safety mode. Warning: some runners may become interactive and hang.",
          "type": "string",
          "enum": [
            "safe"
          ]
        }
      ]
    },
    "RunnerCliConfigRoot": {
      "type": "object",
      "properties": {
        "defaults": {
          "description": "Default normalized runner CLI options applied to all runners (unless overridden).",
          "default": {
            "approval_mode": null,
            "output_format": null,
            "plan_mode": null,
            "sandbox": null,
            "unsupported_option_policy": null,
            "verbosity": null
          },
          "allOf": [
            {
              "$ref": "#/definitions/RunnerCliOptionsPatch"
            }
          ]
        },
        "runners": {
          "description": "Optional per-runner overrides, merged leaf-wise over `defaults`.",
          "default": {},
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/RunnerCliOptionsPatch"
          }
        }
      },
      "additionalProperties": false
    },
    "RunnerCliOptionsPatch": {
      "type": "object",
      "properties": {
        "approval_mode": {
          "description": "Desired approval/permission behavior.",
          "default": null,
          "anyOf": [
            {
              "$ref": "#/definitions/RunnerApprovalMode"
            },
            {
              "type": "null"
            }
          ]
        },
        "output_format": {
          "description": "Desired output format for runner execution.",
          "default": null,
          "anyOf": [
            {
              "$ref": "#/definitions/RunnerOutputFormat"
            },
            {
              "type": "null"
            }
          ]
        },
        "plan_mode": {
          "description": "Desired plan/read-only behavior (when supported by the runner).",
          "default": null,
          "anyOf": [
            {
              "$ref": "#/definitions/RunnerPlanMode"
            },
            {
              "type": "null"
            }
          ]
        },
        "sandbox": {
          "description": "Desired sandbox behavior (when supported by the runner).",
          "default": null,
          "anyOf": [
            {
              "$ref": "#/definitions/RunnerSandboxMode"
            },
            {
              "type": "null"
            }
          ]
        },
        "unsupported_option_policy": {
          "description": "Policy for unsupported options (warn/error/ignore).",
          "default": null,
          "anyOf": [
            {
              "$ref": "#/definitions/UnsupportedOptionPolicy"
            },
            {
              "type": "null"
            }
          ]
        },
        "verbosity": {
          "description": "Desired verbosity (when supported by the runner).",
          "default": null,
          "anyOf": [
            {
              "$ref": "#/definitions/RunnerVerbosity"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "RunnerOutputFormat": {
      "oneOf": [
        {
          "description": "Newline-delimited JSON objects (required for Ralph's streaming parser).",
          "type": "string",
          "enum": [
            "stream_json"
          ]
        },
        {
          "description": "JSON output (may not be streaming; currently treated as unsupported by Ralph execution).",
          "type": "string",
          "enum": [
            "json"
          ]
        },
        {
          "description": "Plain text output (currently treated as unsupported by Ralph execution).",
          "type": "string",
          "enum": [
            "text"
          ]
        }
      ]
    },
    "RunnerPlanMode": {
      "type": "string",
      "enum": [
        "default",
        "enabled",
        "disabled"
      ]
    },
    "RunnerSandboxMode": {
      "type": "string",
      "enum": [
        "default",
        "enabled",
        "disabled"
      ]
    },
    "RunnerVerbosity": {
      "type": "string",
      "enum": [
        "quiet",
        "normal",
        "verbose"
      ]
    },
    "TuiConfig": {
      "description": "TUI-specific configuration.",
      "type": "object",
      "properties": {
        "auto_archive_terminal": {
          "description": "Auto-archive behavior for terminal tasks (Done/Rejected) when set via TUI.",
          "default": null,
          "anyOf": [
            {
              "$ref": "#/definitions/AutoArchiveBehavior"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "UnsupportedOptionPolicy": {
      "type": "string",
      "enum": [
        "ignore",
        "warn",
        "error"
      ]
    }
  }
}
