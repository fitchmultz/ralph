          "maximum": 3650.0,
          "minimum": 0.0
        }
      },
      "additionalProperties": false
    },
    "QueueConfig": {
      "type": "object",
      "properties": {
        "aging_thresholds": {
          "description": "Thresholds for `ralph queue aging` buckets.\n\nDefault: warning>7d, stale>14d, rotten>30d. Ordering must satisfy: warning_days < stale_days < rotten_days.",
          "default": null,
          "anyOf": [
