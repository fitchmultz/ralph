          "maximum": 3650.0,
          "minimum": 0.0
        },
        "stale_days": {
          "description": "Mark as stale when age is strictly greater than this many days.",
          "default": null,
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "maximum": 3650.0,
          "minimum": 0.0
        },
