{
	"version": 1,
	"project_type": "code",
	"ui": {
		"theme": "classic",
		"refresh_seconds": 5
	},
	"logging": {
		"level": "info",
		"file": "",
		"redaction_mode": "secrets_only",
		"max_buffered_bytes": 1048576
	},
	"paths": {
		"data_dir": "data",
		"cache_dir": "~/.ralph/cache/{repo}",
		"pin_dir": ".ralph/pin",
		"done_retention_limit": 100
	},
	"specs": {
		"autofill_scout": false,
		"scout_workflow": false,
		"user_focus": "",
		"runner": "codex",
		"runner_args": [],
		"reasoning_effort": "auto"
	},
	"loop": {
		"sleep_seconds": 5,
		"max_iterations": 0,
		"max_stalled": 3,
		"max_repair_attempts": 2,
		"runner_inactivity_seconds": 1800,
		"only_tags": "",
		"require_main": true,
		"runner": "codex",
		"runner_args": [],
		"reasoning_effort": "auto",
		"dirty_repo": {
			"start_policy": "error",
			"during_policy": "quarantine",
			"allow_untracked": true,
			"quarantine_clean_untracked": false
		}
	},
	"git": {
		"auto_commit": true,
		"auto_push": true
	}
}
